services:
  openwebui:
    image: ghcr.io/open-webui/open-webui:{{docker_openwebui_version}}
    container_name: openwebui
    restart: unless-stopped
{% if docker_openwebui_ports %}
    ports:
{% for line in docker_openwebui_ports %}
      - "{{ line }}"
{% endfor %}
{% endif %}
    volumes:
      - openwebui-data:/app/backend/data
    environment:
      # Leave providers/keys to the UI (PersistentConfig stored in the DB/volume).
      WEBUI_URL: {{ docker_openwebui_uri | to_json }}
{% for key, value in docker_openwebui_environment.items() %}
      {{ key }}: {{ value | to_json }}
{% endfor %}

{% if docker_openwebui_depends_on %}
    depends_on:
{% for service in docker_openwebui_depends_on %}
      - {{ service }}
{% endfor %}
{% endif %}
volumes:
  openwebui-data:
